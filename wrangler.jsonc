{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cyroz",
  "compatibility_date": "2026-06-28",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "build": {
    "command": "npm run build"
  },
  "observability": {
    "enabled": true
  }
}
